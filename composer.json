{
    "name": "kntnt/kntnt-transparent-header-ollie-pro",
    "description": "WordPress plugin that gives Ollie's sticky header a transparent-over-hero mode.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Thomas Barregren",
            "email": "thomas@kntnt.com",
            "homepage": "https://www.kntnt.com"
        }
    ],
    "require": {
        "php": ">=8.5"
    },
    "autoload": {
        "psr-4": {
            "Kntnt\\Transparent_Header_Ollie_Pro\\": "classes/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
