{
    "name": "kntnt/kntnt-transparent-header-ollie-pro",
    "description": "WordPress plugin that gives Ollie's sticky header a transparent-over-hero mode.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Thomas Barregren",
            "email": "thomas@kntnt.com",
            "homepage": "https://www.kntnt.com"
        }
    ],
    "require": {
        "php": ">=8.5"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Kntnt\\Transparent_Header_Ollie_Pro\\": "classes/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "phpcs": "phpcs --standard=phpcs.xml.dist",
        "phpcbf": "phpcbf --standard=phpcs.xml.dist",
        "build": "bash build-release-zip.sh"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
